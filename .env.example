# =============================================================================
# Secure Context Pipeline — environment configuration
# Copy to `.env` (gitignored) and fill in your real values.
# =============================================================================

# --- Anthropic API ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Pipeline configuration -------------------------------------------------
# Obfuscation strategy applied to detected entities.
# One of: tokenize | pseudonymize
OBFUSCATION_STRATEGY=tokenize

# Default confidence threshold below which entities degrade to opaque tokens.
# Range 0.0-1.0. Per-recognizer overrides via code.
DETECTION_CONFIDENCE_THRESHOLD=0.6

# --- Optional: LangSmith tracing --------------------------------------------
# Leave blank to disable. When set, all Anthropic calls are traced so a
# reviewer can independently verify zero-PII-in-transit.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com/
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=secure-context-pipeline

# --- API + UI ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=5173
# Comma-separated list of origins allowed by CORS (UI dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Per-user encryption keys -----------------------------------------------
# Format: USER_KEY_<user_id>=<urlsafe base64-encoded 32-byte Fernet key>
# Auto-generated on first user creation if missing.
# USER_KEY_demo_user=
